{
  "name": "alicewiki-telegram",
  "version": "0.1.0",
  "description": "Telegram bot that fetches Wikipedia articles via LLM",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "init-env": "bun run scripts/init-env.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "express": "^5.1.0",
    "grammy": "^1.35.1",
    "mysql2": "^3.14.1",
    "wikipedia": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.2",
    "typescript": "^6.0.3"
  }
}
